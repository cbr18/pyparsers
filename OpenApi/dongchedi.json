{"openapi":"3.1.0","info":{"title":"Async Car Parsers API (dongchedi)","description":"Direct API for the dongchedi parser service","version":"1.0.0"},"paths":{"/":{"get":{"summary":"Root","operationId":"root__get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/health":{"get":{"summary":"Health Check","description":"Проверка работоспособности API.","operationId":"health_check_health_head","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}},"head":{"summary":"Health Check","description":"Проверка работоспособности API.","operationId":"health_check_health_head","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/blocked":{"get":{"summary":"Get Dongchedi Blocked Status","description":"Короткий probe по dongchedi: list page 1 + one detailed.","operationId":"get_dongchedi_blocked_status_blocked_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/cars":{"get":{"summary":"Get Dongchedi Cars","description":"Получает данные о машинах с dongchedi.","operationId":"get_dongchedi_cars_cars_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/cars/page/{page}":{"get":{"summary":"Get Dongchedi Cars By Page","description":"Получает данные о машинах с dongchedi для конкретной страницы.\n\nArgs:\n    page: Номер страницы (начиная с 1)","operationId":"get_dongchedi_cars_by_page_cars_page__page__get","parameters":[{"name":"page","in":"path","required":true,"schema":{"type":"integer","title":"Page"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/cars/all":{"get":{"summary":"Get Dongchedi All Cars","description":"Получает все машины со всех страниц dongchedi, затем повторно проверяет первые страницы и добавляет только новые машины до первого совпадения.\nЭкономит память: хранит только уникальные id машин.","operationId":"get_dongchedi_all_cars_cars_all_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/cars/incremental":{"post":{"summary":"Get Dongchedi Incremental Cars","description":"Получает только новые машины с dongchedi до первого совпадения с существующими.\n\nArgs:\n    existing_cars: Список существующих машин с полями car_id/sku_id/link","operationId":"get_dongchedi_incremental_cars_cars_incremental_post","requestBody":{"content":{"application/json":{"schema":{"items":{"type":"object"},"type":"array","title":"Existing Cars"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/cars/car/{car_id}":{"get":{"summary":"Get Dongchedi Car Detail","description":"Получает детальную информацию о конкретной машине с dongchedi по ID.\n\nИспользует асинхронный метод async_fetch_car_detail для получения данных.","operationId":"get_dongchedi_car_detail_cars_car__car_id__get","parameters":[{"name":"car_id","in":"path","required":true,"schema":{"type":"string","title":"Car Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/cars/cars":{"post":{"summary":"Get Dongchedi Multiple Cars","description":"Получает детальную информацию о нескольких машинах с dongchedi по их ID.\n\nArgs:\n    request: Запрос со списком ID машин","operationId":"get_dongchedi_multiple_cars_cars_cars_post","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/MultipleCarIdsRequest"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/cars/stats":{"get":{"summary":"Get Dongchedi Stats","description":"Получает статистику по машинам с dongchedi.","operationId":"get_dongchedi_stats_cars_stats_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}},"/cars/enhance/{sku_id}":{"get":{"summary":"Enhance Dongchedi Car","description":"Улучшает машину детальной информацией.\n\nArgs:\n    sku_id: SKU ID машины\n    car_id: Car ID для технических характеристик (опционально)","operationId":"enhance_dongchedi_car_cars_enhance__sku_id__get","parameters":[{"name":"sku_id","in":"path","required":true,"schema":{"type":"string","title":"Sku Id"}},{"name":"car_id","in":"query","required":false,"schema":{"type":"string","title":"Car Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/cars/specs/{car_id}":{"get":{"summary":"Get Dongchedi Car Specs","description":"Получает технические характеристики машины по car_id.\n\nArgs:\n    car_id: Car ID для страницы характеристик","operationId":"get_dongchedi_car_specs_cars_specs__car_id__get","parameters":[{"name":"car_id","in":"path","required":true,"schema":{"type":"string","title":"Car Id"}}],"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/cars/batch-enhance":{"post":{"summary":"Batch Enhance Dongchedi Cars","description":"Массовое улучшение машин детальной информацией.\n\nArgs:\n    request: Словарь с car_ids и их соответствующими sku_ids\n    Пример: {\"car_123\": \"sku_456\", \"car_789\": \"sku_012\"}","operationId":"batch_enhance_dongchedi_cars_cars_batch_enhance_post","requestBody":{"content":{"application/json":{"schema":{"type":"object","title":"Request"}}},"required":true},"responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}},"422":{"description":"Validation Error","content":{"application/json":{"schema":{"$ref":"#/components/schemas/HTTPValidationError"}}}}}}},"/update/full":{"get":{"summary":"Update Dongchedi Full","description":"Эндпоинт для полного обновления данных dongchedi.\nИспользуется Go-приложением для получения всех машин.","operationId":"update_dongchedi_full_update_full_get","responses":{"200":{"description":"Successful Response","content":{"application/json":{"schema":{}}}}}}}},"components":{"schemas":{"HTTPValidationError":{"properties":{"detail":{"items":{"$ref":"#/components/schemas/ValidationError"},"type":"array","title":"Detail"}},"type":"object","title":"HTTPValidationError"},"MultipleCarIdsRequest":{"properties":{"car_ids":{"items":{"type":"string"},"type":"array","title":"Car Ids"}},"type":"object","required":["car_ids"],"title":"MultipleCarIdsRequest"},"ValidationError":{"properties":{"loc":{"items":{"anyOf":[{"type":"string"},{"type":"integer"}]},"type":"array","title":"Location"},"msg":{"type":"string","title":"Message"},"type":{"type":"string","title":"Error Type"}},"type":"object","required":["loc","msg","type"],"title":"ValidationError"}}}}