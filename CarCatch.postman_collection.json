{
  "info": {
    "_postman_id": "ca4f567e-7d12-47a8-b3a8-c5eb24c4e2c4",
    "name": "Car-Catch Parser Services (direct localhost)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Current local parser setup with split services: dongchedi on :5001 and che168 on :5002."
  },
  "item": [
    {
      "name": "Dongchedi Direct (:5001)",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": { "raw": "{{dongchediBaseUrl}}/health", "host": ["{{dongchediBaseUrl}}"], "path": ["health"] } }
        },
        {
          "name": "GET /cars/dongchedi/page/1",
          "request": { "method": "GET", "url": { "raw": "{{dongchediBaseUrl}}/cars/dongchedi/page/1", "host": ["{{dongchediBaseUrl}}"], "path": ["cars", "dongchedi", "page", "1"] } }
        },
        {
          "name": "GET /cars/dongchedi/all",
          "request": { "method": "GET", "url": { "raw": "{{dongchediBaseUrl}}/cars/dongchedi/all", "host": ["{{dongchediBaseUrl}}"], "path": ["cars", "dongchedi", "all"] } }
        },
        {
          "name": "POST /cars/dongchedi/incremental",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"existing_cars\": [\n    { \"car_id\": 123 },\n    { \"sku_id\": \"abc\" }\n  ]\n}" },
            "url": { "raw": "{{dongchediBaseUrl}}/cars/dongchedi/incremental", "host": ["{{dongchediBaseUrl}}"], "path": ["cars", "dongchedi", "incremental"] }
          }
        },
        {
          "name": "GET /cars/dongchedi/car/{car_id}",
          "request": { "method": "GET", "url": { "raw": "{{dongchediBaseUrl}}/cars/dongchedi/car/123456", "host": ["{{dongchediBaseUrl}}"], "path": ["cars", "dongchedi", "car", "123456"] } }
        },
        {
          "name": "POST /cars/dongchedi/cars",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"car_ids\": [\"123\", \"456\"]\n}" },
            "url": { "raw": "{{dongchediBaseUrl}}/cars/dongchedi/cars", "host": ["{{dongchediBaseUrl}}"], "path": ["cars", "dongchedi", "cars"] }
          }
        },
        {
          "name": "GET /cars/dongchedi/stats",
          "request": { "method": "GET", "url": { "raw": "{{dongchediBaseUrl}}/cars/dongchedi/stats", "host": ["{{dongchediBaseUrl}}"], "path": ["cars", "dongchedi", "stats"] } }
        },
        {
          "name": "GET /update/dongchedi/full",
          "request": { "method": "GET", "url": { "raw": "{{dongchediBaseUrl}}/update/dongchedi/full", "host": ["{{dongchediBaseUrl}}"], "path": ["update", "dongchedi", "full"] } }
        }
      ]
    },
    {
      "name": "Che168 Direct (:5002)",
      "item": [
        {
          "name": "GET /health",
          "request": { "method": "GET", "url": { "raw": "{{che168BaseUrl}}/health", "host": ["{{che168BaseUrl}}"], "path": ["health"] } }
        },
        {
          "name": "GET /cars/che168/page/1",
          "request": { "method": "GET", "url": { "raw": "{{che168BaseUrl}}/cars/che168/page/1", "host": ["{{che168BaseUrl}}"], "path": ["cars", "che168", "page", "1"] } }
        },
        {
          "name": "GET /cars/che168/all",
          "request": { "method": "GET", "url": { "raw": "{{che168BaseUrl}}/cars/che168/all", "host": ["{{che168BaseUrl}}"], "path": ["cars", "che168", "all"] } }
        },
        {
          "name": "POST /cars/che168/incremental",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"existing_cars\": [\n    { \"car_id\": \"c1\" }\n  ]\n}" },
            "url": { "raw": "{{che168BaseUrl}}/cars/che168/incremental", "host": ["{{che168BaseUrl}}"], "path": ["cars", "che168", "incremental"] }
          }
        },
        {
          "name": "POST /cars/che168/car",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"car_url\": \"https://www.che168.com/dealer/12345/987654.html\"\n}" },
            "url": { "raw": "{{che168BaseUrl}}/cars/che168/car", "host": ["{{che168BaseUrl}}"], "path": ["cars", "che168", "car"] }
          }
        },
        {
          "name": "POST /che168/detailed/parse",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"car_id\": \"86926831\",\n  \"shop_id\": \"530619\",\n  \"force_update\": false\n}" },
            "url": { "raw": "{{che168BaseUrl}}/che168/detailed/parse", "host": ["{{che168BaseUrl}}"], "path": ["che168", "detailed", "parse"] }
          }
        },
        {
          "name": "POST /che168/detailed/parse-batch",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"cars\": [\n    { \"car_id\": \"86926831\", \"shop_id\": \"530619\", \"force_update\": false },\n    { \"car_id\": \"86928706\", \"shop_id\": \"530619\", \"force_update\": false }\n  ]\n}" },
            "url": { "raw": "{{che168BaseUrl}}/che168/detailed/parse-batch", "host": ["{{che168BaseUrl}}"], "path": ["che168", "detailed", "parse-batch"] }
          }
        },
        {
          "name": "GET /che168/detailed/health",
          "request": { "method": "GET", "url": { "raw": "{{che168BaseUrl}}/che168/detailed/health", "host": ["{{che168BaseUrl}}"], "path": ["che168", "detailed", "health"] } }
        },
        {
          "name": "GET /update/che168/full",
          "request": { "method": "GET", "url": { "raw": "{{che168BaseUrl}}/update/che168/full", "host": ["{{che168BaseUrl}}"], "path": ["update", "che168", "full"] } }
        }
      ]
    }
  ],
  "variable": [
    { "key": "dongchediBaseUrl", "value": "http://localhost:5001", "type": "string" },
    { "key": "che168BaseUrl", "value": "http://localhost:5002", "type": "string" }
  ]
}
