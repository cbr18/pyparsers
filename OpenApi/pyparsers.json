{
  "openapi": "3.1.0",
  "info": {
    "title": "Pyparsers Split Services",
    "version": "2.0.0",
    "description": "Direct local API for the split parser services. Dongchedi runs on localhost:5001, che168 runs on localhost:5002."
  },
  "servers": [
    { "url": "http://localhost:5001", "description": "Dongchedi direct service" },
    { "url": "http://localhost:5002", "description": "Che168 direct service" }
  ],
  "paths": {
    "/": {
      "get": {
        "summary": "Root",
        "responses": { "200": { "description": "Service metadata" } }
      }
    },
    "/health": {
      "get": {
        "summary": "Health check",
        "responses": { "200": { "description": "Service is healthy" } }
      }
    },
    "/blocked/dongchedi": {
      "get": {
        "summary": "Dongchedi blocked probe",
        "description": "Short live probe: parses page 1 and one detailed car to detect whether the current IP is likely blocked by dongchedi.",
        "responses": {
          "200": {
            "description": "Blocked probe result",
            "content": {
              "application/json": {
                "example": {
                  "data": {
                    "source": "dongchedi",
                    "blocked": 0,
                    "checks": { "list": 1, "detailed": 1 },
                    "details": {
                      "list_count": 20,
                      "probe_car_id": "7398947128411625779",
                      "detail_status": 200,
                      "detail_is_banned": 0,
                      "detail_has_images": 1,
                      "detail_has_registration": 1
                    }
                  },
                  "message": "Source availability probe completed",
                  "status": 200
                }
              }
            }
          }
        }
      }
    },
    "/blocked/che168": {
      "get": {
        "summary": "Che168 blocked probe",
        "description": "Short live probe: parses page 1 and one detailed car to detect whether the current IP is likely blocked by che168.",
        "responses": {
          "200": {
            "description": "Blocked probe result",
            "content": {
              "application/json": {
                "example": {
                  "data": {
                    "source": "che168",
                    "blocked": 1,
                    "checks": { "list": 1, "detailed": 0 },
                    "details": {
                      "list_count": 20,
                      "probe_car_id": "86926831",
                      "probe_shop_id": "530619",
                      "detail_error": "upstream timeout"
                    }
                  },
                  "message": "Source availability probe completed",
                  "status": 200
                }
              }
            }
          }
        }
      }
    },
    "/cars/dongchedi": {
      "get": {
        "summary": "Dongchedi first page",
        "responses": { "200": { "description": "Dongchedi listing page" } }
      }
    },
    "/cars/dongchedi/page/{page}": {
      "get": {
        "summary": "Dongchedi page",
        "parameters": [
          { "name": "page", "in": "path", "required": true, "schema": { "type": "integer", "minimum": 1 } }
        ],
        "responses": { "200": { "description": "Dongchedi listing page" } }
      }
    },
    "/cars/dongchedi/all": {
      "get": {
        "summary": "Dongchedi full listing",
        "responses": { "200": { "description": "All available dongchedi pages" } }
      }
    },
    "/cars/dongchedi/incremental": {
      "post": {
        "summary": "Dongchedi incremental parse",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "existing_cars": {
                    "type": "array",
                    "items": { "type": "object", "additionalProperties": true }
                  }
                },
                "required": ["existing_cars"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Incremental parse result" } }
      }
    },
    "/cars/dongchedi/car/{car_id}": {
      "get": {
        "summary": "Dongchedi detailed car",
        "parameters": [
          { "name": "car_id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": { "200": { "description": "Detailed dongchedi car" } }
      }
    },
    "/cars/dongchedi/cars": {
      "post": {
        "summary": "Dongchedi batch detailed cars",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "car_ids": {
                    "type": "array",
                    "items": { "type": "string" }
                  }
                },
                "required": ["car_ids"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Detailed cars batch" } }
      }
    },
    "/cars/dongchedi/stats": {
      "get": {
        "summary": "Dongchedi parser stats",
        "responses": { "200": { "description": "Parser statistics" } }
      }
    },
    "/update/dongchedi/full": {
      "get": {
        "summary": "Dongchedi full update",
        "responses": { "200": { "description": "Update started or completed" } }
      }
    },
    "/cars/che168": {
      "get": {
        "summary": "Che168 first page",
        "responses": { "200": { "description": "Che168 listing page" } }
      }
    },
    "/cars/che168/page/{page}": {
      "get": {
        "summary": "Che168 page",
        "parameters": [
          { "name": "page", "in": "path", "required": true, "schema": { "type": "integer", "minimum": 1 } }
        ],
        "responses": { "200": { "description": "Che168 listing page" } }
      }
    },
    "/cars/che168/all": {
      "get": {
        "summary": "Che168 full listing",
        "responses": { "200": { "description": "All available che168 pages" } }
      }
    },
    "/cars/che168/incremental": {
      "post": {
        "summary": "Che168 incremental parse",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "existing_cars": {
                    "type": "array",
                    "items": { "type": "object", "additionalProperties": true }
                  }
                },
                "required": ["existing_cars"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Incremental parse result" } }
      }
    },
    "/cars/che168/car": {
      "post": {
        "summary": "Che168 detailed car by URL",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "car_url": { "type": "string", "format": "uri" }
                },
                "required": ["car_url"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Detailed che168 car" } }
      }
    },
    "/che168/detailed/parse": {
      "post": {
        "summary": "Che168 detailed parse by identifiers",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "car_id": { "type": "string" },
                  "shop_id": { "type": "string" },
                  "force_update": { "type": "boolean", "default": false }
                },
                "required": ["car_id", "shop_id"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Detailed che168 car" } }
      }
    },
    "/che168/detailed/parse-batch": {
      "post": {
        "summary": "Che168 detailed batch parse",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "cars": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "car_id": { "type": "string" },
                        "shop_id": { "type": "string" },
                        "force_update": { "type": "boolean" }
                      },
                      "required": ["car_id", "shop_id"]
                    }
                  }
                },
                "required": ["cars"]
              }
            }
          }
        },
        "responses": { "200": { "description": "Batch detailed che168 result" } }
      }
    },
    "/che168/detailed/health": {
      "get": {
        "summary": "Che168 detailed parser health",
        "responses": { "200": { "description": "Detailed parser is healthy" } }
      }
    },
    "/update/che168/full": {
      "get": {
        "summary": "Che168 full update",
        "responses": { "200": { "description": "Update started or completed" } }
      }
    }
  }
}
