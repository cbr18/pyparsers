*.ps1
start.ps1

# Environment files
.env
.env.local
.env.*.local

# Temporary files
tmp/
temp/
*.tmp

# Resources (если не нужны в runtime)
# resources/

# Migration scripts (кроме SQL файлов миграций)
migrations/*.ps1
migrations/*.sh
migrations/README.md
migrations/apply*.sql
migrations/example*.sql
migrations/populate*.sql
