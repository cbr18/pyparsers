# Compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
main.exe

# Test binary
*.test

# Output of the coverage tool
*.out

# Debug files
debug_log.txt
*.log

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

